  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "babylonjs": "^9.17.0",
    "babylonjs-loaders": "^9.17.0",
    "babylonjs-serializers": "^9.17.0",
    "react": "^19.2.7",
