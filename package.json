    "emit:castle:check": "node scripts/emit-castle-manifest.mjs --check",
    "emit:world-chests": "node scripts/emit_world_chests.mjs",
    "emit:world-chests:check": "node scripts/emit_world_chests.mjs --check",
    "assets:pipeline": "node scripts/assets_pipeline.mjs",
    "check:assets": "node scripts/assets_pipeline.mjs --check",
    "emit:assets": "node scripts/assets_pipeline.mjs --emit",
    "vendor:meshopt": "node scripts/vendor_meshopt_decoder.mjs",
    "build:terrain-assets": "node scripts/build_terrain_assets.mjs",
    "check:terrain-assets": "node scripts/build_terrain_assets.mjs --check",
    "sync:terrain-assets": "node scripts/sync_terrain_assets.mjs",
    "sync:terrain-assets:check": "node scripts/sync_terrain_assets.mjs --check",
    "prepare:terrain-sources": "node scripts/prepare_terrain_sources.mjs",
    "check:terrain-sources": "node scripts/prepare_terrain_sources.mjs --check",
    "fetch:terrain-source": "node scripts/fetch_terrain_source_set.mjs",
    "check:terrain-source": "node scripts/fetch_terrain_source_set.mjs --check",
    "prebuild": "npm run sync:terrain-assets && npm run emit:castle && npm run emit:world-chests && npm run sync:content",
