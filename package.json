{
  "name": "aurisar-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "sync:content": "node scripts/sync_world_content.mjs",
    "sync:content:check": "node scripts/sync_world_content.mjs --check",
    "emit:castle": "node scripts/emit-castle-manifest.mjs",
    "emit:castle:check": "node scripts/emit-castle-manifest.mjs --check",
    "emit:world-chests": "node scripts/emit_world_chests.mjs",
    "emit:world-chests:check": "node scripts/emit_world_chests.mjs --check",
    "build:terrain-assets": "node scripts/build_terrain_assets.mjs",
    "check:terrain-assets": "node scripts/build_terrain_assets.mjs --check",
    "prepare:terrain-sources": "node scripts/prepare_terrain_sources.mjs",
    "check:terrain-sources": "node scripts/prepare_terrain_sources.mjs --check",
    "prebuild": "npm run build:terrain-assets && npm run emit:castle && npm run emit:world-chests && npm run sync:content",
    "build:glb": "node scripts/build_glb_assets.mjs",
    "build:sentinel": "node scripts/build_gilded_sentinel.mjs",
    "build:gameplay": "node scripts/copy_gameplay_to_public.mjs",
    "bake:tiles": "node scripts/bake_ashwood_tiles.mjs",
    "bake:heightmap": "node scripts/bake_ashwood_heightmap.mjs",
    "verify:worldgen": "node scripts/verify_worldgen.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "babylonjs": "^9.15.0",
    "babylonjs-loaders": "^9.15.0",
    "babylonjs-serializers": "^9.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "react-window": "^2.2.7",
    "recharts": "^3.9.2",
    "spacetimedb": "^2.6.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@gltf-transform/core": "^4.4.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "sharp": "^0.35.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
