# `legacy-peer-deps=true` is required because `eslint-plugin-jsx-a11y@6.10.2`
# declares its peer-dep range as `eslint ^3..^9`, but this project is on
# ESLint 10.2.1. The plugin's runtime API is fully compatible with ESLint 10
# (the plugin uses the standard rule context API, which hasn't changed) — the
# declaration is just conservative.
#
# Without this, `npm ci` fails in CI (which doesn't honor command-line
# `--legacy-peer-deps`). When jsx-a11y publishes a 6.10.3+ that includes
# ESLint 10 in its peer range, this file can be removed.
legacy-peer-deps=true
