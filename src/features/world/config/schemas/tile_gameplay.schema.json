{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurisar.app/schemas/tile_gameplay.schema.json",
  "title": "Tile Gameplay Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "tile", "spawns", "encounter_zones", "waypoints", "pois", "nav_hints"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "created_utc", "source_file"],
      "properties": {
        "version": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "created_utc": { "type": "string", "format": "date-time" },
        "source_file": { "type": "string", "minLength": 1 }
      }
    },
    "tile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tile_id", "world_bounds", "neighbors"],
      "properties": {
        "tile_id": { "type": "string", "pattern": "^T_[0-9]{2}_[0-9]{2}$" },
        "world_bounds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "$ref": "#/$defs/vec3" },
            "max": { "$ref": "#/$defs/vec3" }
          }
        },
        "neighbors": {
          "type": "array",
          "items": { "type": "string", "pattern": "^T_[0-9]{2}_[0-9]{2}$" },
          "uniqueItems": true
        }
      }
    },
    "spawns": {
      "type": "array",
      "items": { "$ref": "#/$defs/spawnPoint" }
    },
    "encounter_zones": {
      "type": "array",
      "items": { "$ref": "#/$defs/encounterZone" }
    },
    "waypoints": {
      "type": "array",
      "items": { "$ref": "#/$defs/waypoint" }
    },
    "pois": {
      "type": "array",
      "items": { "$ref": "#/$defs/poi" }
    },
    "nav_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["walkable_cost_scale", "blocked_volumes"],
      "properties": {
        "walkable_cost_scale": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "blocked_volumes": {
          "type": "array",
          "items": { "$ref": "#/$defs/aabb" }
        }
      }
    }
  },
  "$defs": {
    "vec3": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "aabb": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "$ref": "#/$defs/vec3" },
        "max": { "$ref": "#/$defs/vec3" }
      }
    },
    "spawnPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["net_id", "mob_type", "position", "yaw_deg", "respawn_sec", "max_alive"],
      "properties": {
        "net_id": { "type": "string", "pattern": "^[A-Z0-9_\\-]{4,64}$" },
        "mob_type": { "type": "string", "minLength": 1, "maxLength": 64 },
        "position": { "$ref": "#/$defs/vec3" },
        "yaw_deg": { "type": "number", "minimum": -360, "maximum": 360 },
        "respawn_sec": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "max_alive": { "type": "integer", "minimum": 1, "maximum": 200 },
        "leash_radius_m": { "type": "number", "minimum": 1, "maximum": 500 },
        "aggro_radius_m": { "type": "number", "minimum": 1, "maximum": 200 }
      }
    },
    "encounterZone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["net_id", "shape", "center", "size", "waves"],
      "properties": {
        "net_id": { "type": "string", "pattern": "^[A-Z0-9_\\-]{4,64}$" },
        "shape": { "type": "string", "enum": ["box", "sphere", "capsule"] },
        "center": { "$ref": "#/$defs/vec3" },
        "size": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "z"],
          "properties": {
            "x": { "type": "number", "minimum": 0.1 },
            "y": { "type": "number", "minimum": 0.1 },
            "z": { "type": "number", "minimum": 0.1 }
          }
        },
        "waves": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mob_type", "count", "spawn_interval_sec"],
            "properties": {
              "mob_type": { "type": "string" },
              "count": { "type": "integer", "minimum": 1, "maximum": 500 },
              "spawn_interval_sec": { "type": "number", "minimum": 0.1, "maximum": 600 }
            }
          }
        }
      }
    },
    "waypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["net_id", "position", "tags"],
      "properties": {
        "net_id": { "type": "string", "pattern": "^[A-Z0-9_\\-]{4,64}$" },
        "position": { "$ref": "#/$defs/vec3" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "poi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["net_id", "kind", "position"],
      "properties": {
        "net_id": { "type": "string", "pattern": "^[A-Z0-9_\\-]{4,64}$" },
        "kind": { "type": "string", "enum": ["loot", "vista", "quest", "dungeon_gate", "castle_marker"] },
        "position": { "$ref": "#/$defs/vec3" }
      }
    }
  }
}
