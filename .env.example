# Supabase — public client config (anon key is safe to expose, but
# keeping it in env makes credential rotation easier and keeps secrets
# out of git history if the URL ever changes).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Preview / dev access mode.
# In dev (`npm run dev`) preview mode is always enabled and uses
# VITE_PREVIEW_PIN if set, falling back to "1234".
# In a production build it is stripped from the bundle entirely
# unless you set VITE_ALLOW_PREVIEW=true at build time (e.g. for staging).
VITE_ALLOW_PREVIEW=false
VITE_PREVIEW_PIN=1234
